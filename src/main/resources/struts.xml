<!DOCTYPE struts PUBLIC
    "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN"
    "http://struts.apache.org/dtds/struts-2.5.dtd">

<struts>
    <constant name="struts.devMode" value="true"/>

    <package name="default" namespace="/" extends="struts-default">

        <!-- =========================
             COMMON
        ========================== -->
        <action name="index">
            <result type="redirect">player-management</result>
        </action>

        <!-- =========================
             PLAYER
        ========================== -->
        <action name="player-management" class="com.example.action.PlayerAction" method="list">
            <result name="success">/WEB-INF/pages/player-management/player-management.jsp</result>
        </action>

        <action name="player-detail" class="com.example.action.PlayerAction" method="detail">
            <result name="success">/WEB-INF/pages/player-detail/player-detail.jsp</result>
        </action>

        <action name="player-update" class="com.example.action.PlayerAction" method="update">
            <result name="success" type="redirect">player-management</result>
        </action>

        <action name="player-create" class="com.example.action.PlayerAction" method="create">
            <result name="success" type="redirect">player-management</result>
        </action>

        <!-- =========================
             CLUB
        ========================== -->
        <action name="club-management" class="com.example.action.ClubAction" method="list">
            <result name="success">/WEB-INF/pages/club-management/club-management.jsp</result>
        </action>

        <action name="club-detail" class="com.example.action.ClubAction" method="detail">
            <result name="success">/WEB-INF/pages/club-detail/club-detail.jsp</result>
        </action>

        <action name="club-edit-player" class="com.example.action.ClubAction" method="editPlayerFromClub">
            <result name="success">/WEB-INF/pages/player-club-edit/player-club-edit.jsp</result>
        </action>

        <action name="player-club-update" class="com.example.action.ClubAction" method="updatePlayerFromClub">
            <result name="success" type="redirect">club-detail?clubId=${clubId}</result>
        </action>

        <action name="club-update" class="com.example.action.ClubAction" method="update">
            <result name="success" type="redirect">club-management</result>
        </action>

        <action name="club-create" class="com.example.action.ClubAction" method="create">
            <result name="success" type="redirect">club-management</result>
        </action>

        <action name="club-add-player-form" class="com.example.action.ClubAction" method="showAddPlayerForm">
            <result>/WEB-INF/pages/club-add-player/club-add-player.jsp</result>
        </action>

        <action name="club-add-player" class="com.example.action.ClubAction" method="addPlayerToClub">
            <result type="redirect">club-detail?clubId=${clubId}</result>
        </action>

        <!-- =========================
             COUNTRY
        ========================== -->
        <action name="country-management" class="com.example.action.CountryAction" method="list">
            <result>/WEB-INF/pages/country-management/country-management.jsp</result>
        </action>

        <action name="country-create-form" class="com.example.action.CountryAction" method="createForm">
            <result>/WEB-INF/pages/country-management/country-create.jsp</result>
        </action>

        <action name="country-create" class="com.example.action.CountryAction" method="create">
            <result name="success" type="redirect">country-management</result>
            <result name="input" type="redirect">country-management</result>
        </action>

        <action name="country-detail" class="com.example.action.CountryAction" method="detail">
            <result>/WEB-INF/pages/country-management/country-detail.jsp</result>
            <result name="error" type="redirectAction">country-management</result>
        </action>

        <action name="country-delete" class="com.example.action.CountryAction" method="delete">
            <result type="redirectAction">country-management</result>
        </action>

    </package>
</struts>