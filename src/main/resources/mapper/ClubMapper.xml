<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.mapper.ClubMapper">

    <!-- ========================= -->
    <!-- RESULT MAP: CLUB -->
    <!-- ========================= -->
    <resultMap id="ClubResultMap" type="Club">
        <id property="id" column="id"/>
        <result property="clubName" column="club_name"/>
        <result property="imgUrl" column="img_url"/>
    </resultMap>


    <!-- ========================= -->
    <!-- RESULT MAP: PLAYER -->
    <!-- ========================= -->
    <resultMap id="PlayerResultMap" type="Player">
        <id property="id" column="player_id"/>
        <result property="fullName" column="full_name"/>
        <result property="position" column="position"/>
        <result property="birthYear" column="birth_year"/>
    </resultMap>


    <!-- ========================= -->
    <!-- RESULT MAP: PLAYER_CLUB -->
    <!-- ========================= -->
    <resultMap id="PlayerClubResultMap" type="PlayerClub">
        <id property="id" column="player_club_id"/>
        <result property="yearJoined" column="year_joined"/>
        <result property="yearLeft" column="year_left"/>
        <result property="appearances" column="appearances"/>
        <result property="goals" column="goals"/>
        <result property="assists" column="assists"/>
        <result property="cleanSheets" column="clean_sheets"/>
        <association property="player" resultMap="PlayerResultMap"/>
    </resultMap>


    <!-- ========================= -->
    <!-- RESULT MAP: CLUB WITH PLAYERS -->
    <!-- ========================= -->
    <resultMap id="ClubWithPlayersResultMap" type="Club">
        <id property="id" column="club_id"/>
        <result property="clubName" column="club_name"/>
        <result property="imgUrl" column="img_url"/>

        <collection property="playerClubs" resultMap="PlayerClubResultMap"/>
    </resultMap>

    <select id="findAll" resultType="Club">
        SELECT *
        FROM clubs
        ORDER BY id
    </select>

    <select id="findById" resultType="Club">
        SELECT *
        FROM clubs
        WHERE id = #{id}
    </select>

    <select id="getClubWithPlayers" resultMap="ClubWithPlayersResultMap">
        SELECT
            c.id as club_id,
            c.club_name,
            c.img_url,

            pc.id as player_club_id,
            pc.year_joined,
            pc.year_left,
            pc.appearances,
            pc.goals,
            pc.assists,
            pc.clean_sheets,
            
            p.id as player_id,
            p.full_name,
            p.position,
            p.birth_year
        FROM clubs c
        LEFT JOIN player_clubs pc ON c.id = pc.club_id
        LEFT JOIN players p ON pc.player_id = p.id
        WHERE c.id = #{id}
    </select>

    <insert id="insert" parameterType="Club" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO clubs (club_name, img_url)
        VALUES (#{clubName}, #{imgUrl})
    </insert>

    <update id="update" parameterType="Club">
        UPDATE clubs
        SET club_name = #{clubName}, img_url = #{imgUrl}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="Integer">
        DELETE FROM clubs
        WHERE id = #{id}
    </delete>

</mapper>