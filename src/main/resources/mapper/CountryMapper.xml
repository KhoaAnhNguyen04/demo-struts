<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.mapper.CountryMapper">

    <resultMap id="CountryResultMap" type="Country">
        <id property="id" column="id"/>
        <result property="countryName" column="country_name"/>
        <result property="imgUrl" column="img_url"/>
    </resultMap>

    <select id="findAll" resultMap="CountryResultMap">
        SELECT id, country_name, img_url
        FROM countries
        ORDER BY id DESC
    </select>

    <select id="findById" parameterType="long" resultMap="CountryResultMap">
        SELECT id, country_name, img_url
        FROM countries
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="Country">
        INSERT INTO countries (country_name, img_url)
        VALUES (#{countryName}, #{imgUrl})
    </insert>

    <delete id="delete" parameterType="long">
        DELETE FROM countries
        WHERE id = #{id}
    </delete>

</mapper>