<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.mapper.PlayerMapper">

    <resultMap id="ClubResultMap" type="Club">
        <id property="id" column="club_id"/>
        <result property="clubName" column="club_name"/>
        <result property="imgUrl" column="club_img_url"/>
    </resultMap>

    <resultMap id="PlayerClubResultMap" type="PlayerClub">
        <id property="id" column="player_club_id"/>
        <result property="yearJoined" column="year_joined"/>
        <result property="yearLeft" column="year_left"/>
        <association property="club" resultMap="ClubResultMap"/>
    </resultMap>

    <resultMap id="CountryResultMap" type="Country">
        <id property="id" column="country_id"/>
        <result property="countryName" column="country_name"/>
        <result property="imgUrl" column="country_img_url"/>
    </resultMap>

    <resultMap id="PlayerWithClubsResultMap" type="Player">
        <id property="id" column="player_id"/>
        <result property="fullName" column="full_name"/>
        <result property="position" column="position"/>
        <result property="birthYear" column="birth_year"/>
        <result property="shirtNumber" column="shirt_number"/>
        <association property="country" resultMap="CountryResultMap"/>
        <collection property="playerClubs" resultMap="PlayerClubResultMap"/>
    </resultMap>

    <resultMap id="PlayerWithCountryResultMap" type="Player">
        <id property="id" column="player_id"/>
        <result property="fullName" column="full_name"/>
        <result property="position" column="position"/>
        <result property="birthYear" column="birth_year"/>
        <result property="shirtNumber" column="shirt_number"/>
        <association property="country" resultMap="CountryResultMap"/>
    </resultMap>

    <sql id="PlayerColumns">
        p.id AS player_id,
        p.full_name,
        p.position,
        p.birth_year,
        p.shirt_number
    </sql>

    <sql id="CountryColumns">
        co.id AS country_id,
        co.country_name,
        co.img_url AS country_img_url
    </sql>

    <sql id="ClubColumns">
        c.id AS club_id,
        c.club_name,
        c.img_url AS club_img_url
    </sql>

    <select id="getPlayerWithClubs" parameterType="int" resultMap="PlayerWithClubsResultMap">
        SELECT
        <include refid="PlayerColumns"/>
,
        <include refid="CountryColumns"/>
,
        <include refid="ClubColumns"/>
,
            pc.id AS player_club_id,
            pc.year_joined,
            pc.year_left
        FROM players p
        LEFT JOIN countries co ON p.country_id = co.id
        LEFT JOIN player_clubs pc ON p.id = pc.player_id
        LEFT JOIN clubs c ON pc.club_id = c.id
        WHERE p.id = #{id}
        ORDER BY pc.year_joined DESC
    </select>

    <select id="findAll" resultMap="PlayerWithCountryResultMap">
        SELECT
        <include refid="PlayerColumns"/>
,
        <include refid="CountryColumns"/>
        FROM players p
        LEFT JOIN countries co ON p.country_id = co.id
    </select>

    <select id="findById" parameterType="int" resultMap="PlayerWithCountryResultMap">
        SELECT
        <include refid="PlayerColumns"/>
,
        <include refid="CountryColumns"/>
        FROM players p
        LEFT JOIN countries co ON p.country_id = co.id
        WHERE p.id = #{id}
    </select>

    <insert id="insert" parameterType="Player">
        INSERT INTO players (
            full_name,
            position,
            birth_year,
            shirt_number
        )
        VALUES (
            #{fullName},
            #{position},
            #{birthYear},
            #{shirtNumber}
        )
    </insert>

    <update id="update" parameterType="Player">
        UPDATE players
        SET
            full_name = #{fullName},
            position = #{position},
            birth_year = #{birthYear},
            shirt_number = #{shirtNumber}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="int">
        DELETE FROM players
        WHERE id = #{id}
    </delete>

</mapper>