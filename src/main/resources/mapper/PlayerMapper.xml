<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.mapper.PlayerMapper">

    <resultMap id="PlayerResultMap" type="Player">
        <id property="id" column="id"/>
        <result property="fullName" column="full_name"/>
        <result property="position" column="position"/>
        <result property="birthYear" column="birth_year"/>
        <result property="shirtNumber" column="shirt_number"/>

        <collection property="clubs" ofType="Club">
            <id property="id" column="id"/>
            <result property="clubName" column="club_name"/>
        </collection>
    </resultMap>

    <select id="getPlayerWithClubs" resultMap="PlayerResultMap">
        SELECT 
            p.id as id,
            p.full_name,
            p.position,
            p.birth_year,
            p.shirt_number,
            c.id as id,
            c.club_name

        FROM players p
        LEFT JOIN player_clubs pc ON p.id = pc.player_id
        LEFT JOIN clubs c ON pc.club_id = c.id
        WHERE p.id = #{id}
    </select>

    <select id="findAll" resultType="Player">
        SELECT * FROM players
    </select>

    <select id="findById" parameterType="int" resultType="Player">
        SELECT * FROM players
        WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="Player">
    INSERT INTO players(full_name, position, birth_year, shirt_number)
    VALUES(#{fullName}, #{position}, #{birthYear}, #{shirtNumber})
    </insert>

    <update id="update" parameterType="Player">
        UPDATE players
        SET full_name = #{fullName}, position = #{position}, birth_year = #{birthYear}, shirt_number = #{shirtNumber}
        WHERE id = #{id}
    </update>

    <delete id="delete" parameterType="int">
        DELETE FROM players
        WHERE id = #{id}
    </delete>

</mapper>